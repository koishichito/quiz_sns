# このファイルを .env にコピーして値を埋める: cp .env.example .env
# .env は git に入れない(.gitignore で除外済み)

# 形式: mysql+pymysql://ユーザー:パスワード@ホスト:ポート/DB名?charset=utf8mb4
#        ^^^^^^^^^^^^^ 「DB方言+ドライバ」の指定。pymysql を明示する
DATABASE_URL=mysql+pymysql://quiz_user:quiz_pass@127.0.0.1:3306/quiz_db?charset=utf8mb4

# --- Keycloak(配られた環境の値に差し替える)---
# SECRET_KEY は無くなった: トークンの発行(署名)はKeycloakの仕事になり、
# アプリは公開鍵で検証するだけなので、秘密の署名鍵を持つ必要が消えた

# 認証サーバ本体のURL(末尾スラッシュ不要)
KEYCLOAK_SERVER_URL=http://localhost:8080

# 所属する realm 名。トークンの iss は {SERVER_URL}/realms/{REALM} になる
KEYCLOAK_REALM=quiz-sns

# トークン取得時にクライアントが名乗るID(トークンの検証自体には使わない)
KEYCLOAK_CLIENT_ID=quiz-sns-api

# aud(宛先)クレームの検証を有効化したい場合のみ設定する。
# 未設定なら aud は検証しない(Keycloak側のマッパー設定に依存するため)
# KEYCLOAK_AUDIENCE=quiz-sns-api
