# このファイルを .env にコピーして値を埋める: cp .env.example .env
# .env は git に入れない(.gitignore に追加すること)

# 形式: mysql+pymysql://ユーザー:パスワード@ホスト:ポート/DB名?charset=utf8mb4
#        ^^^^^^^^^^^^^ 「DB方言+ドライバ」の指定。pymysql を明示する
DATABASE_URL=mysql+pymysql://quiz_user:quiz_pass@127.0.0.1:3306/quiz_db?charset=utf8mb4

# JWT署名鍵。これが漏れるとトークンを偽造される。
# 生成例: openssl rand -hex 32
SECRET_KEY=change-me-to-random-hex

ACCESS_TOKEN_EXPIRE_MINUTES=60
